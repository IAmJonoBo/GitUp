{
  "name": "gitup",
  "displayName": "GitUp",
  "description": "GitUp - Generate and apply code scaffolds",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:gitup.open"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gitup.open",
        "title": "GitUp: Open"
      }
    ],
    "configuration": {
      "title": "GitUp",
      "properties": {
        "gitup.nodeVersion": {
          "type": "string",
          "default": "",
          "description": "Preferred Node.js version to use when generating scaffolds (fallback if nvm is unavailable)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "build": "npm run compile",
    "test": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gitup/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "~25.2.1",
    "@types/vscode": "^1.109.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/vsce": "^2.15.0"
  }
}
